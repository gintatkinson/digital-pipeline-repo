{
  "meta": {
    "version": "1.0.0",
    "description": "Test verification rules",
    "upstream_repository": "gintatkinson/digital-pipeline-repo",
    "constitution_path": ".pipeline/constitution.md",
    "profiles_directory": ".pipeline/profiles"
  },
  "tracker_rules": {
    "provider": "github",
    "issue_id_placeholder": "#[IssueID]",
    "prefix_normalization_regex": "^(epic|feat|us|uc|feature|user[- ]story|use[- ]case)[s]?(?:[- ]*\\d+\\s*[:\\-]?|:)\\s*",
    "numeric_prefix": "#",
    "alphanumeric_prefix": "",
    "keys": {
      "issue_id": "number",
      "title": "title",
      "labels": "labels",
      "state": "state",
      "closed_state_value": "CLOSED",
      "open_state_value": "OPEN"
    },
    "labels": {
      "epic": "epic",
      "feature": "feature",
      "user_story": "user-story",
      "use_case": "use-case"
    }
  },
  "backlog_directories": {
    "epics": "test_project/docs/epics",
    "features": "test_project/docs/features",
    "user_stories": "test_project/docs/user-stories",
    "use_cases": "test_project/docs/use-cases",
    "schemas": "test_project/schema"
  },
  "target_directories": {
    "react": "test_project/web_react",
    "flutter": "test_project/app_flutter"
  },
  "react_rules": {
    "file_extensions": [".ts", ".tsx"],
    "exclusions": ["node_modules", "build", "dist", "coverage", ".git"]
  },
  "flutter_rules": {
    "file_extensions": [".dart"],
    "exclusions": ["build", ".dart_tool", ".git"]
  },
  "validation_rules": {
    "uml_primitives": ["String", "Integer", "Real", "Boolean"],
    "visibility_prefixes": ["+", "-", "#", "~"],
    "relationship_connectors": "(\\*--|o--|<\\|--|--|-->)",
    "choice_stereotypes": ["<<choice>>"],
    "sequence_replies": ["-->", "-->>"],
    "fragment_keywords": ["alt", "loop", "opt", "par", "critical", "else", "option"],
    "use_case_flow_limit": 2,
    "use_case_step_limit": 2,
    "max_body_characters": 65536,
    "schema_exclude_keywords": ["description", "reference", "organization", "contact", "revision", "import", "prefix", "namespace", "yang-version"],
    "multiplicity_regex": "\\[[^\\]]+\\]",
    "essential_feature_sections": ["Class Diagram", "Interface Requirements"],
    "required_diagrams": {
      "epic": ["classDiagram", "stateDiagram-v2"],
      "feature": ["classDiagram"],
      "user_story": ["sequenceDiagram"],
      "use_case": ["(?:graph|flowchart)", "stateDiagram"]
    },
    "mermaid_dotted_link_regex": "-\\.-*->\\s*\\|",
    "forbidden_diagram_types": ["erDiagram"],
    "use_case_stadium_nodes_only": true,
    "use_case_undirected_actor_links_only": true,
    "use_case_extend_arrow_direction_check": true,
    "naming_conventions": {
      "use_case": "^uc-\\d{2}-[a-z0-9\\-]+\\.md$"
    },
    "test_data_shape_regex": "###\\s+1\\.\\s+Test\\s+Data\\s+Shape",
    "test_data_block_regex": "```json",
    "bdd_scenario_regexes": [
      "(?:Given|When|Then)",
      "As a\\s+.*\\s+I want to\\s+.*\\s+so that\\s+.*"
    ],
    "required_features_matrix_regex": "##\\s+Required\\s+Features(?:\\s+Matrix)?(.*?)(?=##|\\Z)",
    "checkbox_syntax_regex": "-\\s+\\[[ xX]\\]\\s+.*",
    "use_case_alternate_flows_header": "## 5. Alternate and Exception Flows",
    "use_case_numbered_step_regex": "\\b\\d+\\.\\s+\\S+",
    "use_case_flow_list_regex": "-\\s+\\*\\*\\d[a-zA-Z]\\..*?(?=(?:-\\s+\\*\\*\\d[a-zA-Z]\\.)|\\Z)",
    "realization_matrix_header": "## 8. Realization Matrix",
    "realization_stories_header": "### Required User Stories",
    "realization_features_header": "### Required Features",
    "schema_patterns": {
      ".yang": {
        "name_regex": "\\bmodule\\s+([a-zA-Z0-9_\\-]+)",
        "patterns": [
          "\\btypedef\\s+([a-zA-Z0-9_\\-]+)",
          "\\bleaf\\s+([a-zA-Z0-9_\\-]+)",
          "\\bleaf-list\\s+([a-zA-Z0-9_\\-]+)",
          "\\bcontainer\\s+([a-zA-Z0-9_\\-]+)",
          "\\blist\\s+([a-zA-Z0-9_\\-]+)",
          "\\bgrouping\\s+([a-zA-Z0-9_\\-]+)",
          "\\bchoice\\s+([a-zA-Z0-9_\\-]+)",
          "\\bcase\\s+([a-zA-Z0-9_\\-]+)",
          "\\bidentity\\s+([a-zA-Z0-9_\\-]+)",
          "\\banydata\\s+([a-zA-Z0-9_\\-]+)",
          "\\banyxml\\s+([a-zA-Z0-9_\\-]+)",
          "\\brpc\\s+([a-zA-Z0-9_\\-]+)",
          "\\bnotification\\s+([a-zA-Z0-9_\\-]+)",
          "\\baction\\s+([a-zA-Z0-9_\\-]+)"
        ]
      }
    },
    "alternative_schema_extensions": [".yaml", ".yml", ".json", ".proto", ".asn", ".asn1", ".msg", ".srv", ".xsd"],
    "required_sections": {
      "epic": [
        ["##\\s+1\\.\\s+Context", "## 1. Context"],
        ["##\\s+2\\.\\s+Requirements\\s+&\\s+Checklist", "## 2. Requirements & Checklist"],
        ["##\\s+3\\.\\s+Architecture", "## 3. Architecture"],
        ["##\\s+4\\.\\s+Operational\\s+Considerations", "## 4. Operational Considerations"],
        ["##\\s+5\\.\\s+Security\\s+&\\s+Governance", "## 5. Security & Governance"],
        ["##\\s+6\\.\\s+Source\\s+References", "## 6. Source References"],
        ["##\\s+System-Level\\s+UML\\s+Class\\s+Diagram", "## System-Level UML Class Diagram"],
        ["##\\s+System\\s+State\\s+Machine\\s+Diagram", "## System State Machine Diagram"]
      ],
      "feature": [
        ["##\\s+UML\\s+Class\\s+Diagram", "## UML Class Diagram"],
        ["##\\s+Interface\\s+Requirements", "## Interface Requirements"],
        ["###\\s+1\\.\\s+Test\\s+Data\\s+Shape", "### 1. Test Data Shape"],
        ["###\\s+4\\.\\s+Interactive\\s+Flow\\s+&\\s+States", "### 4. Interactive Flow & States"]
      ],
      "user_story": [
        ["##\\s+UML\\s+Sequence\\s+Diagram", "## UML Sequence Diagram"],
        ["##\\s+Required\\s+Features", "## Required Features"]
      ],
      "use_case": [
        ["##\\s+UML\\s+Diagrams", "## UML Diagrams"],
        ["##\\s+1\\.\\s+Actors", "## 1. Actors"],
        ["##\\s+2\\.\\s+Preconditions", "## 2. Preconditions"],
        ["##\\s+3\\.\\s+Trigger", "## 3. Trigger"],
        ["##\\s+4\\.\\s+Main\\s+Success\\s+Scenario", "## 4. Main Success Scenario"],
        ["##\\s+5\\.\\s+Alternate\\s+(?:and|&)\\s+Exception\\s+Flows", "## 5. Alternate and Exception Flows"],
        ["##\\s+6\\.\\s+Postconditions", "## 6. Postconditions"],
        ["##\\s+8\\.\\s+Realization\\s+Matrix", "## 8. Realization Matrix"]
      ]
    }
  }
}
