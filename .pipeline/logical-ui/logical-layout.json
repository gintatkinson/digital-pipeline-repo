{
  "meta": {
    "version": "1.0.0",
    "schema_name": "gke_management_dashboard"
  },
  "theme": {
    "modes": ["light", "dark", "system"],
    "colors": {
      "primary_accent": "color.brand.primary",
      "background": {
        "light": "color.background.light",
        "dark": "color.background.dark"
      },
      "surface": {
        "light": "color.surface.light",
        "dark": "color.surface.dark"
      },
      "status": {
        "ok": "color.alarm.cleared",
        "warning": "color.alarm.minor",
        "critical": "color.alarm.critical"
      }
    },
    "typography": {
      "fonts": ["Outfit", "Roboto", "system-ui"],
      "scale": "high-density"
    }
  },
  "navigation": {
    "sidebar": {
      "collapsible": true,
      "default_expanded": true,
      "items": [
        {
          "label": "Topology Viewer",
          "route": "/topology",
          "icon": "hub"
        },
        {
          "label": "Resource Directory",
          "route": "/resources",
          "icon": "dns"
        }
      ]
    }
  },
  "layout": {
    "root_container": {
      "type": "SidebarLayout",
      "id": "main_shell",
      "children": [
        {
          "type": "HierarchyTreeSelector",
          "id": "resource_tree",
          "props": {
            "width": "spacing.layout-sidebar-width",
            "hierarchy": ["Folder", "Project", "Resource"]
          },
          "bindings": {
            "data_source": "gcp:resource-manager",
            "selection_target": "selected_managed_object"
          }
        },
        {
          "type": "SplitWorkspace",
          "id": "workspace_split",
          "props": {
            "axis": "horizontal",
            "resizable": true,
            "default_ratio": 0.4,
            "reconfigurable": true,
            "min_size_pixels": "spacing.layout-min-pane-size"
          },
          "children": [
            {
              "type": "TopographicalView",
              "id": "topology_pane",
              "props": {
                "dimensions": 3,
                "enable_time_playback": true,
                "interactive": true,
                "allow_pan_zoom": true
              },
              "bindings": {
                "data_source": "yang:spatial-temporal-topology/topology[@topology-id='selected_managed_object']",
                "selection_target": "active_focused_node",
                "coordinate_mapping": {
                  "x": "location/longitude",
                  "y": "location/latitude",
                  "z": "location/altitude",
                  "t": "location/timestamp",
                  "trajectory": "location/trajectory-vector"
                },
                "depth_selector": {
                  "default_hops": 2,
                  "max_hops": 5
                },
                "relationship_filters": [
                  "termination-point-to-node",
                  "link-to-node",
                  "layer-transition",
                  "orbital-conjunction"
                ]
              }
            },
            {
              "type": "TabbedContainer",
              "id": "details_and_relations_tab",
              "props": {
                "tab_position": "bottom"
              },
              "children": [
                {
                  "type": "TableView",
                  "id": "sub_elements_table",
                  "props": {
                    "label": "Elements",
                    "sortable": true,
                    "filterable": true,
                    "high_density": true,
                    "display_all_attributes": true
                  },
                  "bindings": {
                    "data_source": "yang:network-topology/topology/node[@node-id='active_focused_node']/contained-elements"
                  }
                },
                {
                  "type": "TableView",
                  "id": "active_alarms_table",
                  "props": {
                    "label": "Alarms",
                    "sortable": true,
                    "filterable": true,
                    "high_density": true,
                    "display_all_attributes": true
                  },
                  "bindings": {
                    "data_source": "yang:alarm-management/alarms[target-resource='active_focused_node']"
                  }
                },
                {
                  "type": "TableView",
                  "id": "historical_events_table",
                  "props": {
                    "label": "Events",
                    "sortable": true,
                    "filterable": true,
                    "high_density": true,
                    "display_all_attributes": true
                  },
                  "bindings": {
                    "data_source": "yang:event-log/events[source-resource='active_focused_node']"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
