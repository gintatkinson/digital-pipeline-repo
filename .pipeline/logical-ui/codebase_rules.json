{
  "meta": {
    "version": "1.0.0",
    "description": "Dynamic verification rules and parameters for pipeline and codebase compliance",
    "upstream_repository": "gintatkinson/digital-pipeline-repo",
    "troubleshooting_instruction": "If you believe this failure is due to a bug in the pipeline tooling, please report it to: {upstream_repo}",
    "constitution_path": ".pipeline/constitution.md",
    "profiles_directory": ".pipeline/profiles",
    "walkthrough_directory": "docs/designs",
    "walkthrough_pattern": "feat-{number}-solution.md",
    "reconciliation_script_path": "skills/spec-orchestrator/scripts/reconcile_backlog.py",
    "behavioral_triggers_path": "rules/behavioral_triggers.json"
  },
  "tracker_rules": {
    "provider": "github",
    "commands": {
      "list_issues": ["gh", "issue", "list", "--limit", "1000", "--state", "all", "--json", "number,title,state,labels"],
      "edit_issue": ["gh", "issue", "edit", "{number}", "--body-file", "{temp_path}"],
      "close_issue": ["gh", "issue", "close", "{number}", "--comment", "{comment}"]
    }
  },
  "backlog_directories": {
    "epics": "docs/epics",
    "features": "docs/features",
    "user_stories": "docs/user-stories",
    "use_cases": "docs/use-cases",
    "schemas": "yang"
  },
  "target_directories": {
    "react": "web_react",
    "flutter": "app_flutter"
  },
  "react_rules": {
    "file_extensions": [".ts", ".tsx", ".js", ".jsx", ".css", ".scss"],
    "exclusions": ["node_modules", "build", "dist", "coverage", ".git"],
    "ui_directories": ["components", "views"],
    "network_directories": ["io"],
    "forbidden_words": [],
    "write_lock_keywords": ["writelock", "lockwrite", "sendlock", "mutationlock"],
    "selection_keywords": ["onSelect", "onNodeSelect", "onSelectionChange", "setSelectedNode", "setSelectedId", "dispatch"],
    "interaction_keywords": ["onClick", "onDrag", "onMouseDown", "onPointerDown"],
    "playhead_clamp_regex": ["0\\.9\\b", "1\\.1\\b"],
    "playhead_clamp_range": [0.90, 1.10],
    "ast_compliance_method": "stopPropagation",
    "viewport_file_patterns": ["viewport"],
    "network_file_patterns": ["gateway", "socket", "client", "connection"]
  },
  "flutter_rules": {
    "file_extensions": [".dart"],
    "exclusions": ["build", ".dart_tool", ".git"],
    "ui_directories": ["widgets", "screens"],
    "network_directories": ["io"],
    "selection_setters": ["set selected", "set active", "set selection", "setSelectedNode", "setActiveNode"],
    "selection_triggers": ["onChanged", "onSelected", "notifyListeners", "dispatch"],
    "loop_guard_keywords": ["userinitiated", "programmatic", "fromuser", "isuser", "userinteraction"],
    "forbidden_words": [],
    "write_lock_keywords": ["writelock", "lockwrite", "sendlock", "mutationlock"],
    "playhead_clamp_regex": ["0\\.9\\b", "1\\.1\\b"],
    "ffi_keywords": ["dart:ffi"],
    "ffi_finalizer_keywords": ["nativefinalizer"],
    "ffi_refcount_keywords": ["refcount", "referencecount", "addref", "release", "finalizer"],
    "viewport_file_patterns": ["viewport"],
    "network_file_patterns": ["gateway", "socket", "client", "connection"]
  },
  "python_rules": {
    "exclusions": ["node_modules", "build", "dist", "coverage", ".git", "skills", ".tessl-plugin"]
  },
  "spec_rules": {
    "dom_leak_patterns": ["\\baria-\\w+", "\\brole=[\"']\\w+"],
    "pixel_leak_patterns": ["\\b\\d+px\\b"],
    "spec_files": [".pipeline/logical-ui/logical-components.md"],
    "design_tokens_path": ".pipeline/logical-ui/design-tokens.json"
  },
  "validation_rules": {
    "uml_primitives": ["String", "Integer", "Real", "Boolean"],
    "visibility_prefixes": ["+", "-", "#", "~"],
    "relationship_connectors": "(\\*--|o--|<\\|--|--|-->)",
    "choice_stereotypes": ["<<choice>>"],
    "sequence_replies": ["-->"],
    "fragment_keywords": ["alt", "loop", "opt", "par", "critical", "else", "option"],
    "use_case_flow_limit": 2,
    "use_case_step_limit": 2,
    "max_body_characters": 65536,
    "yang_exclude_keywords": ["description", "reference", "organization", "contact", "revision", "import", "prefix", "namespace", "yang-version"],
    "multiplicity_regex": "\\[[^\\]]+\\]",
    "essential_feature_sections": ["Class Diagram", "Functional UI"],
    "required_diagrams": {
      "epic": ["classDiagram", "stateDiagram-v2"],
      "feature": ["classDiagram"],
      "user_story": ["sequenceDiagram"],
      "use_case": ["(?:graph|flowchart)", "stateDiagram"]
    },
    "mermaid_dotted_link_regex": "-\\.-*->\\s*\\|",
    "forbidden_diagram_types": ["erDiagram"],
    "use_case_stadium_nodes_only": true,
    "use_case_undirected_actor_links_only": true,
    "use_case_extend_arrow_direction_check": true,
    "naming_conventions": {
      "use_case": "^uc-\\d{2}-[a-z0-9\\-]+\\.md$"
    },
    "required_sections": {
      "epic": [
        ["##\\s+1\\.\\s+Context", "## 1. Context"],
        ["##\\s+2\\.\\s+Requirements\\s+&\\s+Checklist", "## 2. Requirements & Checklist"],
        ["##\\s+3\\.\\s+Architecture", "## 3. Architecture"],
        ["##\\s+4\\.\\s+Operational\\s+Considerations", "## 4. Operational Considerations"],
        ["##\\s+5\\.\\s+Security\\s+&\\s+Governance", "## 5. Security & Governance"],
        ["##\\s+6\\.\\s+Source\\s+References", "## 6. Source References"],
        ["##\\s+System-Level\\s+UML\\s+Class\\s+Diagram", "## System-Level UML Class Diagram"],
        ["##\\s+System\\s+State\\s+Machine\\s+Diagram", "## System State Machine Diagram"]
      ],
      "feature": [
        ["##\\s+UML\\s+Class\\s+Diagram", "## UML Class Diagram"],
        ["##\\s+Functional\\s+UI\\s+Requirements", "## Functional UI Requirements"],
        ["###\\s+1\\.\\s+Test\\s+Data\\s+Shape", "### 1. Test Data Shape"],
        ["###\\s+4\\.\\s+Interactive\\s+Flow\\s+&\\s+States", "### 4. Interactive Flow & States"]
      ],
      "user_story": [
        ["##\\s+UML\\s+Sequence\\s+Diagram", "## UML Sequence Diagram"],
        ["##\\s+Required\\s+Features", "## Required Features"]
      ],
      "use_case": [
        ["##\\s+UML\\s+Diagrams", "## UML Diagrams"],
        ["##\\s+1\\.\\s+Actors", "## 1. Actors"],
        ["##\\s+2\\.\\s+Preconditions", "## 2. Preconditions"],
        ["##\\s+3\\.\\s+Trigger", "## 3. Trigger"],
        ["##\\s+4\\.\\s+Main\\s+Success\\s+Scenario", "## 4. Main Success Scenario"],
        ["##\\s+5\\.\\s+Alternate\\s+(?:and|&)\\s+Exception\\s+Flows", "## 5. Alternate and Exception Flows"],
        ["##\\s+6\\.\\s+Postconditions", "## 6. Postconditions"],
        ["##\\s+8\\.\\s+Realization\\s+Matrix", "## 8. Realization Matrix"]
      ]
    }
  }
}
